{
  "expo": {
    "name": "AdityaFoodsUsers",
    "slug": "AdityaFoodsUsers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/main.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/main.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.ram123s.AdityaFoodsUsers",
      "permissions": []
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/main.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/main.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "react-native-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "0c1e6f3b-5d1d-4862-bc2b-df847052f42c"
      }
    },
    "owner": "surya_expo"
  }
}




